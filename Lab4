<html>
<head>
    <title>INST377 - Lab 4</title>
    <style>
        body {
            background-color: lightblue;
            font-family: Arial, sans-serif;
            text-align: center;
        }
        h1 {
            font-size: 36px;
            margin-bottom: 30px;
        }
        .section {
            display: inline-block;
            margin: 10px;
            padding: 20px;
            background-color: purple;
            color: white;
            border: 2px solid white;
            border-radius: 10px;
        }
        input {
            padding: 10px;
            margin-right: 10px;
        }
        button {
            padding: 10px 20px;
            background-color: white;
            color: purple;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }
        button:hover {
            background-color: lightgray;
        }
    </style>
</head>
<body>
    <h1 id="pageHeading">INST377 - Lab 4</h1>

    <div class="section">
        <form id="alertForm">
            <label for="name">Name: </label>
            <input type="text" id="name" name="name" required>
            <button type="button" onclick="alertName()">Alert Me!</button>
        </form>
    </div>

    <div class="section">
        <button type="button" onclick="changeColor()">Change Color</button>
    </div>

    <div class="section">
        <form id="textForm">
            <label for="textTester">Text Tester: </label>
            <input type="text" id="textTester" name="textTester">
            <button type="button" onclick="validateText()">Validate Text</button>
        </form>
    </div>

    <div class="section">
        <button type="button" onclick="addText()">Add Text</button>
    </div>

    <script>
        function alertName() {
            let name = document.getElementById("name").value;
            if (name) {
                alert("Hi " + name + "!");
            }
        }

        let isBlue = true;
        function changeColor() {
            if (isBlue) {
                document.body.style.backgroundColor = "green";
                isBlue = false;
            } else {
                document.body.style.backgroundColor = "lightblue";
                isBlue = true;
            }
        }

        function validateText() {
            let text = document.getElementById("textTester").value;
            let validation = /[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]+/;
            if (validation.test(text)) {
                alert("Text contains special characters!");
            } else {
                alert("Text is valid!");
            }
        }

        function addText() {
            let heading = document.getElementById("pageHeading");
            heading.innerHTML += " Add Text";
        }
    </script>
</body>
</html>
